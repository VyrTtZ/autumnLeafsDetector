<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Label?>

<VBox xmlns="http://javafx.com/javafx/17.0.2-ea"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.autumnleavesdetector.MainController"
      fx:id="root" alignment="TOP_CENTER" spacing="0"
      style="-fx-background-color: #F8F7F2;">

    <HBox fx:id="header" alignment="CENTER" spacing="10"
          style="-fx-padding: 16 24; -fx-border-color: #E0DED6; -fx-border-width: 0 0 1 0;">
        <Label text="Leaf Finder" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
    </HBox>

    <HBox fx:id="cardRow" alignment="CENTER" spacing="16"
          style="-fx-padding: 40 32;"/>

</VBox>